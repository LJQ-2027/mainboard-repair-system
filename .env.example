# ============================================
# 智能主板维修系统 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# ⚠️  安全警告：
#   - .env 已在 .gitignore 中排除，请勿提交到 Git
#   - API Key 和 SECRET_KEY 是敏感凭据，泄露将导致安全风险
#   - 如怀疑密钥泄露，请立即轮换
# ============================================

# ---------- API 平台配置（必填）----------
# Kimi Code / Anthropic Claude / DeepSeek / Kimi 的 API Key
# 获取地址:
#   Kimi Code: https://www.kimi.com/code/console
#   Anthropic: https://console.anthropic.com
#   DeepSeek:  https://platform.deepseek.com
#   Kimi:      https://platform.moonshot.cn
ANTHROPIC_API_KEY=sk-your-api-key-here

# 手动指定平台 (可选，不设置则自动识别前缀)
# deepseek / kimi / kimi-code / anthropic
# 注意：deepseek 和 kimi 的 key 都是 sk- 开头，必须手动指定！
AI_PROVIDER=kimi

# 模型选择 (可选)
# kimi-code:   kimi-for-coding / kimi-k2-thinking / kimi-k2-thinking-turbo
# kimi:        moonshot-v1-vision-preview / moonshot-v1-128k / 32k / 8k
# anthropic:   claude-sonnet-4-6 / claude-opus-4-7
# deepseek:    deepseek-chat / deepseek-reasoner
AI_MODEL=moonshot-v1-vision-preview

# ---------- 安全配置（必填）----------
# JWT 签名密钥，至少 32 字符
# 生成方式: openssl rand -base64 48
# ⚠️ 生产环境务必修改，不可与 API Key 相同，不可使用默认值
SECRET_KEY=

# ---------- CORS 配置 ----------
# 生产环境必须设置为实际域名（多个用逗号分隔）
# 示例: https://repair.your-company.com,https://admin.your-company.com
CORS_ORIGINS=http://localhost:3000

# 是否允许跨域携带凭证
CORS_ALLOW_CREDENTIALS=true

# 允许的 HTTP 方法
CORS_METHODS=GET,POST,PUT,DELETE

# 允许的请求头
CORS_HEADERS=*

# ---------- 数据库配置 ----------
# 留空则使用 SQLite (backend/data/mainboard.db)，适合开发/单机部署
# 多用户生产环境请使用 PostgreSQL:
#   DATABASE_URL=postgresql://user:password@host:5432/mainboard_repair
DATABASE_URL=

# ---------- 服务端点 ----------
PORT=8899

# ---------- 日志与监控 ----------
# text = 开发友好，json = 生产环境（便于日志系统采集）
LOG_FORMAT=text

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Prometheus 指标端点 (/metrics)
ENABLE_METRICS=true

# Sentry 错误追踪（可选）
# 获取 DSN: https://sentry.io
SENTRY_DSN=

# ---------- 安全加固 ----------
# HSTS（HTTP Strict Transport Security）
# 仅在 HTTPS 已配置且稳定运行后开启
ENABLE_HSTS=false
HSTS_MAX_AGE=31536000

# 接口速率限制
RATE_LIMIT_ENABLED=true
