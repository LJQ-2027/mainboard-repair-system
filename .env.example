# ============================================
# AI 代理服务器 - 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================

# 你的 API Key (必填)
ANTHROPIC_API_KEY=sk-your-api-key-here

# JWT 签名密钥（必填，至少 32 字符，不可与 API Key 相同）
# 生成方式：openssl rand -base64 48
SECRET_KEY=

# CORS 来源（生产环境必须指定具体来源，多个用逗号分隔）
# 示例：http://localhost:3000,https://your-domain.com
CORS_ORIGINS=http://localhost:3000

# 是否允许跨域携带凭证（Cookie/Authorization header）
CORS_ALLOW_CREDENTIALS=true

# 允许的跨域 HTTP 方法
CORS_METHODS=GET,POST,PUT,DELETE

# 允许的跨域请求头
CORS_HEADERS=*

# 手动指定平台 (可选，不设置则自动识别)
# Kimi 视觉 (推荐原理图分析): kimi
# Anthropic Claude:            anthropic
# DeepSeek 纯文本:             deepseek
AI_PROVIDER=kimi

# 模型选择 (可选，仅 Kimi 平台)
# moonshot-v1-vision-preview  → 支持图片分析
# moonshot-v1-128k / 32k / 8k → 纯文本
AI_MODEL=moonshot-v1-vision-preview

# 服务端点
PORT=8899

# 安全头部：是否启用 HSTS（仅在 HTTPS 生产环境开启）
# 开启后浏览器将强制使用 HTTPS 访问，开发环境请保持 false
ENABLE_HSTS=false
# HSTS 最大有效期（秒），默认 1 年
HSTS_MAX_AGE=31536000
