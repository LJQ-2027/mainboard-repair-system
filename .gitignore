# SQLite 数据库文件（运行时生成，不提交）
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# 环境变量 - 包含 API Key，绝对不能提交
.env

# 日志文件
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Node.js
node_modules/

# 内部数据（含真实链接，不提交到公开仓库）
data/internal/

# 临时文件
~$*
*.tmp
.local/
